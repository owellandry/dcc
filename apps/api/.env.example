# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://dcc:dcc@localhost:5432/dcc

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://192.168.1.23:3000

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=smtp_password
EMAIL_FROM="DCC <no-reply@example.com>"

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://192.168.1.23:3000

# ── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/v1/auth/oauth/github/callback

# ── Storage (Cloudflare R2 / S3) ─────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=dcc-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
